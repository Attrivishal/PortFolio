# ─── Server ───────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# ─── Frontend URL (for CORS) ──────────────────────────
# In production, set to your Vercel URL
FRONTEND_URL=http://localhost:3000

# ─── Optional: Email Notifications ───────────────────
# If you want email alerts when a message is received
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=vishalattri196@gmail.com
